# .env.deploy.example - 部署配置模板
# 请将此文件复制为 .env.deploy 并填写服务器信息

# 服务器公网 IP
SERVER_IP=12.34.56.78

# 服务器登录用户 (建议使用有写权限的非 root 用户)
SERVER_USER=deploy

# 项目在服务器上的目标目录 (绝对路径)
# 例如: /var/www/jiansi-deck
SERVER_PATH=/var/www/jiansi-deck

# 可选: Nginx 配置文件所在的远程目录 (如 /etc/nginx/conf.d/vue-ppt.conf)
# NGINX_PATH=/etc/nginx/conf.d/vue-ppt.conf

# 可选: 如果你的服务器端口不是 22，请取消注释并设置
# SERVER_PORT=2222
